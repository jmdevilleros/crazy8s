# **********************************************************************
# Kivy User Interface definition for Crazy8s game
# **********************************************************************

#:kivy 2.3.0

#: import RiseInTransition kivy.uix.screenmanager.RiseInTransition

#:set MARGIN 10
#:set BACKGROUND_COLOR (0, 0.2, 0.1)
#:set TABLE_COLOR (0, 0.5, 0)
#:set BORDER_COLOR (0.2, 0.4, 0.2)
#:set MSG_COLOR (1, 1, 0, 1)
#:set STATUS_COLOR (0.5, 0.5, 0.5, 1)


# **********************************************************************
ScreenManager:
    transition: RiseInTransition()
    SplashScreen:
    SetupScreen:
    GameScreen:

# **********************************************************************
<SplashScreen>:
    name: 'SplashScreen'
    Image:
        source: app.IMAGE_DIR + 'splash_image.png'

# **********************************************************************
<SetupScreen>:
    name: 'SetupScreen'
    requested_players: nplayers.value
    requested_humans: nhumans.value
    requested_autoplay: autoplay.active
    requested_autoplay_delay: autospeed.value
    Frame:
        padding: MARGIN * 2
        spacing: MARGIN / 2
        size_hint: 0.6, 0.6
        Label:
            size_hint: 0.5, 0.1
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}
            text: 'CRAZY EIGHTS GAME'
        Label:
            size_hint: 0.5, 0.05
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}
            halign: 'center'
            text:
                'Set your preferences and click "Play"'
        Frame:
            # Number of players
            orientation: 'horizontal'
            size_hint: 1, 0.25
            Label:
                size_hint: 0.4, 1
                pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                text: 'Number of players'
            FloatLayout:
                size_hint: 0.6, 1
                Slider:
                    id: nplayers
                    size_hint: 1, 0.8
                    pos_hint: {'center_x': 0.5, 'top': 1}
                    range: (2, 10)
                    step: 1
                    value: app.num_players
                Label:
                    size_hint: 1, 0.2
                    pos_hint: {'top':0.3, 'center_x': 0.5}
                    font_size: 12
                    text:
                        '{:.0f} player{}'.format(\
                        nplayers.value, 's' if nplayers.value != 1 else '')
        Frame:
            # Number of humans
            orientation: 'horizontal'
            size_hint: 1, 0.25
            Label:
                size_hint: 0.4, 1
                pos_hint: {'center_x': 0.5, 'center_y': 0.5 }
                text: 'Number of humans'
            FloatLayout:
                size_hint: 0.6, 1
                Slider:
                    id: nhumans
                    size_hint: 1, 0.8
                    pos_hint: {'center_x': 0.5, 'top': 1}
                    range: (0, nplayers.value)
                    step: 1
                    value: app.num_humans
                Label:
                    size_hint: 1, 0.2
                    pos_hint: {'top':0.3, 'center_x': 0.5}
                    font_size: 12
                    text:
                        '{:.0f} human{}'.format(\
                        nhumans.value, 's' if nhumans.value != 1 else '')
        Frame:
            # Automatic play
            orientation: 'horizontal'
            size_hint: 1, 0.25
            Label:
                size_hint: 0.4, 1
                pos_hint: {'center_x': 0.5, 'center_y': 0.5 }
                text: 'Automatic play'
            CheckBox:
                id: autoplay
                size_hint: 0.1, 1
                pos_hint: {'center_x': 0.5, 'center_y': 0.5 }
            FloatLayout:
                size_hint: 0.6, 1
                disabled: not autoplay.active
                Slider:
                    id: autospeed
                    size_hint: 1, 0.8
                    pos_hint: {'center_x': 0.5, 'top':1}
                    range: (0, 10)
                    step: 0.5
                    value: app.autoplay_delay
                Label:
                    size_hint: 1, 0.2
                    pos_hint: {'center_x': 0.5, 'top': 0.3}
                    font_size: 12
                    text: '{} seconds'.format(autospeed.value)
        Button:
            size_hint: 0.5, 0.1
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}
            text: 'Play'
            on_release: root.check_preferences()

# **********************************************************************
<GameScreen>:
    name: 'GameScreen'
    player_zone: player_zone
    draw_zone: draw_zone
    discard_zone: discard_zone
    msg: msg
    Frame:
        spacing: -MARGIN/2
        Zone:
            id: player_zone
            size_hint: 1, 4
            spacing: MARGIN
            cols: 5
            rows: 2
        Zone:
            id: draw_zone
            size_hint: 1, 2
            spacing: -650
        Zone:
            id: discard_zone
            size_hint: 1, 2
            spacing: -600
        Zone:
            id: message_zone
            size_hint: 1, 1
            Label:
                id: msg
                color: MSG_COLOR
        Zone:
            id: status_zone
            size_hint: 1, 1
            StatusLabel:
                text:
                    'Player: {}'.format(app.current_player.name \
                    if app.current_player is not None else '')
            StatusLabel:
                text: 'Turn: {}'.format(app.turn)
            StatusLabel:
                text:
                    'Autoplay is ' + \
                    (('On (' + str(app.autoplay_delay) + 's)') \
                    if app.autoplay else 'Off')
            FloatLayout:
                disabled: not app.autoplay
                Slider:
                    size_hint: 1, 0.8
                    pos_hint: {'center_x': 0.5, 'top':1}
                    range: (0, 10)
                    step: 0.5
                    value: app.autoplay_delay
                    on_value: app.autoplay_delay = self.value
        Zone:
            id: control_zone
            size_hint: 1, 1
            padding: MARGIN * 1.5
            spacing: MARGIN
            Button:
                disabled:
                    app.autoplay and app.turn > 0 and app.winner is None
                text: 'New game'
                on_release: app.root.current = 'SetupScreen'
            Button:
                disabled:
                    app.autoplay and app.turn > 0 and app.winner is None
                text: 'Reset game'
                on_release: app.create_game()
            Button:
                disabled:
                    (app.autoplay and app.turn > 0 and app.winner is None) \
                    or app.winner is not None
                text:
                    'Start game' if app.turn < 1 else 'Next turn'
                on_release: app.start_turn()
            Button:
                text:
                    'Toggle autoplay' \
                    if (app.turn < 1 or app.winner is not None) \
                    else ('Pause game' if app.autoplay else 'Continue game')
                on_release: app.autoplay = not app.autoplay

# **********************************************************************
<Frame@BoxLayout>:
    orientation: 'vertical'
    pos_hint: {'center_x': 0.5, 'center_y': 0.5}
    padding: MARGIN
    spacing: MARGIN
    canvas.before:
        Color:
            rgb: TABLE_COLOR
        RoundedRectangle:
            pos: (self.x + MARGIN/2, self.y + MARGIN/2)
            size: (self.width - MARGIN, self.height - MARGIN)
            source: app.IMAGE_DIR + 'table_background.jpg'
        Color:
            rgb: BORDER_COLOR
        Line:
            rounded_rectangle:
                (self.x + MARGIN, self.y + MARGIN,
                self.width - MARGIN * 2, self.height - MARGIN * 2,
                MARGIN)
                
# **********************************************************************
<Zone@GridLayout>:
    pos_hint: {'center_x': 0.5, 'center_y': 0.5}
    padding: MARGIN * 2
    rows: 1
    canvas.before:
        Color:
            rgb: BORDER_COLOR
        Line:
            rounded_rectangle:
                (self.x + MARGIN, self.y + MARGIN,
                self.width - MARGIN * 2, self.height - MARGIN * 2,
                MARGIN)

# **********************************************************************
<StatusLabel@Label>:
    font_size: 14
    color: STATUS_COLOR
